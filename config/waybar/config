{
  "layer": "top",
  "modules-left": ["sway/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["custom/playerctl","pulseaudio", "network", "battery", "tray"],
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}",
    "format-icons": {
      "1":"ΌΑΘ",
      "2":"ΎΕκ",
      "3":"ΎΕι",
      "4":"ΎΑφ",
      "5":"ΎΑΒ",
    }
  },
  "sway/window": {
    "max-length": 50,
    "tooltip": false
  },
  "clock": {
    "format-alt": "{:%d-%m-%Y}",
    "tooltip": false
  },
  "battery": {
    "interval": 60,
    "states": {
      "good": 100,
      "warning": 25,
      "critical": 10
    },
    "format": "{icon}   {capacity}%",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
    "tooltip": false
  },
  "network": {
    "format-wifi": "ΎΘτ  {essid} ({signalStrength}%)",
    "format-ethernet": "ΎΔΒ {ifname}",
    "format-disconnected": "έγι Disconnected",
    "interval": 5,
    "tooltip": false,
  },
  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{icon}ΎΛΦ {volume}%",
    "format-muted": "ΎΑο",
    "format-icons": {
      "headphones": "ΎΑξ",
      "handsfree": "ΎΨΡ",
      "headset": "ΎΨΡ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑπ", "ΎΑρ"]
    },
    "tooltip": false
  },
  "custom/playerctl": {
    "format": "ΎΑΒ   {}",
    "max-length": 40,
    "interval": 5,
    "exec": "playerctl metadata --format '{{ artist }} - {{ title }}'",
    "tooltip": false
  }
}
